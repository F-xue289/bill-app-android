<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ContentProvider 演示"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#303133"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 说明卡片 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 什么是 ContentProvider？"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#673AB7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ContentProvider 是数据访问接口层，负责封装底层数据存储，其他组件通过 ContentResolver 访问数据。"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="URI: content://com.example.comsumptionrecord.expenses/expenses"
                android:textSize="11sp"
                android:textColor="#909399"
                android:background="#F0F0F0"
                android:padding="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 操作按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_insert"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="插入数据"
                android:textSize="14sp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btn_query"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="查询数据"
                android:textSize="14sp"
                android:backgroundTint="#2196F3" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_update"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="更新数据"
                android:textSize="14sp"
                android:backgroundTint="#FF9800" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="删除数据"
                android:textSize="14sp"
                android:backgroundTint="#F44336" />

        </LinearLayout>

    </LinearLayout>

    <!-- 结果显示区域 -->
    <TextView
        android:id="@+id/tv_result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="点击按钮查看结果..."
        android:textSize="12sp"
        android:textColor="#333333"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:gravity="top" />

</LinearLayout>